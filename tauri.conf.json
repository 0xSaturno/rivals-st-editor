{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "rivals-st-editor",
    "version": "0.7.0",
    "identifier": "com.rivals-st-editor.saturn",
    "build": {
        "frontendDist": "./RSTE"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Rivals ST Editor",
                "width": 1400,
                "height": 900,
                "dragDropEnabled": true,
                "zoomHotkeysEnabled": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "./build/icon.png",
            "./build/icon.ico"
        ],
        "resources": {
            "./RSTE/assets": "assets",
            "./RSTE/css": "css",
            "./RSTE/fonts": "fonts",
            "./RSTE/js": "js",
            "./UassetToolRivals/src/UAssetTool/bin/Release/net8.0/win-x64/publish/UAssetTool.exe": "tools/UAssetTool.exe",
            "./LocresReader/publish_single/MarvelRivalsLocresReader.exe": "tools/MarvelRivalsLocresReader.exe",
            "./LocresReader/publish_single/oo2core_9_win64.dll": "tools/oo2core_9_win64.dll"
        }
    }
}