{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "rivals-st-editor",
    "version": "1.0.0",
    "identifier": "com.rivals-st-editor.saturn",
    "build": {
        "frontendDist": "./dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "Rivals ST Editor",
                "width": 1400,
                "height": 900,
                "dragDropEnabled": true,
                "zoomHotkeysEnabled": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "./build/icon.png",
            "./build/icon.ico"
        ],
        "resources": {
            "./UassetToolRivals/src/UAssetTool/bin/Release/net8.0/win-x64/publish/UAssetTool.exe": "tools/UAssetTool.exe",
            "./LocresReader/publish_single/LocresReader.exe": "tools/LocresReader.exe",
            "./LocresReader/publish_single/oo2core_9_win64.dll": "tools/oo2core_9_win64.dll"
        }
    }
}
